# OmniDeck Environment Configuration
# Copy to .env and fill in strong secrets for production.

# Frontend
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-strong-admin-password
SECRET_KEY=change-me-long-random-secret-key

# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-strong-postgres-password

# MongoDB
MONGO_INITDB_ROOT_USERNAME=admin
MONGO_INITDB_ROOT_PASSWORD=change-me-strong-mongo-password

# Redis
REDIS_PASSWORD=change-me-strong-redis-password

# MinIO
MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=change-me-strong-minio-password

# Public endpoint used in developer connection strings.
# Leave empty for local development (uses internal Docker hostnames).
OMNIDECK_PUBLIC_HOST=

# Backup / Offsite
GCS_BACKUP_BUCKET=omnideck-backups-bucket
